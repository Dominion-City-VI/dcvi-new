{
  "name": "vitejs-shadcnui-mobx-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "dev:api": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "node -e \"try{require('husky').install()}catch(e){}\"",
    "format": "prettier --write .",
    "check:types": "tsc --pretty --noEmit",
    "check:format": "prettier --check \"src/**/*.+(ts|tsx|json)\"",
    "check": "yarn lint && yarn check:format && yarn check:types",
    "test": "vitest",
    "test:ci": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "src/**/*.+(ts|tsx|json)": "prettier --write --ignore-unknown"
  },
  "dependencies": {
